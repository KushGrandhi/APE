# Ollama configuration
OLLAMA_HOST=http://localhost:11434

# Vision tool configuration
# VISION_SOURCE: "mock" (default), "images", or "camera"
VISION_SOURCE=mock
# Model used for image analysis (must support vision)
VISION_MODEL=gemma3:4b
# For camera mode: RTSP/IP camera URL (omit to use default webcam)
# CAMERA_URL=rtsp://192.168.1.100:554/stream
# Number of frames to capture in burst (default: 5)
BURST_FRAMES=5
# Seconds between frame captures (default: 0.5)
BURST_INTERVAL_SEC=0.5
# For images mode: pass the directory path as the source argument

# Audio tool configuration
# AUDIO_SOURCE: "mock" (default), "file", or "mic"
AUDIO_SOURCE=mock
# Whisper model size: tiny, base, small, medium, large (default: base)
WHISPER_MODEL=base
# Seconds to record from microphone (default: 5)
MIC_DURATION_SEC=5

# Gesture tool configuration
# GESTURE_SOURCE: "mock" (default), "image", or "camera"
GESTURE_SOURCE=mock
# Model used for gesture analysis (must support vision)
GESTURE_MODEL=gemma3:4b
# For camera mode: separate camera URL for gesture cam (omit to use default webcam)
# GESTURE_CAMERA_URL=rtsp://192.168.1.101:554/stream
# Number of frames to capture in burst (default: 3)
GESTURE_BURST_FRAMES=3
# Seconds between gesture frame captures (default: 0.5)
GESTURE_BURST_INTERVAL_SEC=0.5
